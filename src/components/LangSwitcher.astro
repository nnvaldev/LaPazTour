---
import { idiomas } from '../i18n/translations.js';
---
<div class="lang-switch" role="group" aria-label="Language">
  {
    idiomas.map((lang) => (
      <button
        type="button"
        class="lang-btn"
        data-lang={lang.code}
        aria-pressed={lang.code === 'es' ? 'true' : 'false'}
        title={lang.label}
      >
        <span aria-hidden="true">{lang.flag}</span>
        <span>{lang.label}</span>
      </button>
    ))
  }
</div>

<script>
  import { dict, t } from '../i18n/translations.js';

  const KEY = 'lpt-lang';

  function getLang() {
    try {
      return localStorage.getItem(KEY) || 'es';
    } catch {
      return 'es';
    }
  }

  function setLang(lang) {
    try {
      localStorage.setItem(KEY, lang);
    } catch {}
    document.documentElement.lang = lang;
    applyI18n(lang);
    window.dispatchEvent(new CustomEvent('lpt-lang-change', { detail: { lang } }));
  }

  function applyI18n(lang) {
    document.querySelectorAll('[data-i18n]').forEach((el) => {
      const key = el.getAttribute('data-i18n');
      if (!key) return;
      el.textContent = t(key, lang);
    });

    document.querySelectorAll('[data-i18n-html]').forEach((el) => {
      const key = el.getAttribute('data-i18n-html');
      if (!key) return;
      el.innerHTML = t(key, lang);
    });

    document.querySelectorAll('[data-i18n-placeholder]').forEach((el) => {
      const key = el.getAttribute('data-i18n-placeholder');
      if (!key) return;
      el.setAttribute('placeholder', t(key, lang));
    });

    document.querySelectorAll('[data-i18n-aria]').forEach((el) => {
      const key = el.getAttribute('data-i18n-aria');
      if (!key) return;
      el.setAttribute('aria-label', t(key, lang));
    });

    // option "all attractions"
    const opt = document.querySelector('#selectRuta option[value=""]');
    if (opt) opt.textContent = t('map.all', lang);

    document.querySelectorAll('.lang-btn').forEach((btn) => {
      const active = btn.getAttribute('data-lang') === lang;
      btn.setAttribute('aria-pressed', active ? 'true' : 'false');
      btn.classList.toggle('is-active', active);
    });

    const themeBtn = document.getElementById('themeToggle');
    if (themeBtn) {
      const dark = document.documentElement.classList.contains('dark');
      themeBtn.setAttribute('aria-label', t(dark ? 'theme.light' : 'theme.dark', lang));
    }
  }

  window.lptT = (key, vars) => t(key, getLang(), vars);
  window.lptGetLang = getLang;

  document.querySelectorAll('.lang-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const lang = btn.getAttribute('data-lang');
      if (lang && dict[lang]) setLang(lang);
    });
  });

  // init
  const initial = getLang();
  document.documentElement.lang = initial;
  applyI18n(initial);
</script>
