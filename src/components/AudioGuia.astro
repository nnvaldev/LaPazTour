---
import { lugares } from '../data/data.js';
const conAudio = lugares.filter((l) => l.audio);
---
<div class="grid gap-6 sm:grid-cols-2">
  {
    conAudio.map((l) => (
      <article class="border-l-[3px] border-dorado bg-white/60 py-3 pl-4 pr-2 dark:border-neon dark:bg-[#123556]/50">
        <div class="flex items-start justify-between gap-2">
          <h4 class="font-sans text-base font-bold heading">{l.nombre}</h4>
          {l.accesible && (
            <span class="shrink-0 rounded-full bg-verde-ok/10 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-verde-ok dark:bg-neon/15 dark:text-neon">
              Accesible
            </span>
          )}
        </div>
        <p class="text-soft-xs mt-1 text-sm">{l.descripcion}</p>
        <audio controls class="mt-3 w-full" preload="none">
          <source src={l.audio} type="audio/mpeg" />
          Tu navegador no soporta audio.
        </audio>
      </article>
    ))
  }
</div>
{
  conAudio.length === 0 && (
    <p class="text-soft text-sm">Aún no hay audio guías disponibles.</p>
  )
}
