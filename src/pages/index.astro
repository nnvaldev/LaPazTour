---
import Layout from '../components/Layout.astro';
import Mapa from '../components/Mapa.astro';
import Rutas from '../components/Rutas.astro';
import Comercios from '../components/Comercios.astro';
import Aliados from '../components/Aliados.astro';
import Diferencial from '../components/Diferencial.astro';
import Conversor from '../components/Conversor.astro';
import Experiencias from '../components/Experiencias.astro';
import LangSwitcher from '../components/LangSwitcher.astro';
import '../styles/globals.css';
import { lugares } from '../data/data.js';

const accesibles = lugares.filter((l) => l.accesible && !l.ocultoLista).length;
---

<Layout title="La Paz Tour — La Paz sin barreras">
  <header class="site-hero relative overflow-hidden">
    <nav class="relative z-10 mx-auto flex max-w-6xl items-center justify-between gap-3 px-4 py-4">
      <a href="/" class="font-sans text-lg font-bold tracking-tight text-white">
        La Paz Tour
        <span class="ml-1 text-dorado">·</span>
      </a>
      <div class="flex items-center gap-2 md:gap-4">
        <div class="hidden gap-4 text-sm text-white/75 lg:flex">
          <a href="#conversor" class="transition hover:text-dorado" data-i18n="nav.currency">Moneda</a>
          <a href="#mapa-section" class="transition hover:text-dorado" data-i18n="nav.map">Mapa</a>
          <a href="#rutas" class="transition hover:text-dorado" data-i18n="nav.routes">Rutas</a>
          <a href="#experiencias" class="transition hover:text-dorado" data-i18n="nav.book">Reservar</a>
        </div>
        <LangSwitcher />
        <button type="button" id="themeToggle" class="theme-toggle" aria-pressed="false" data-i18n-aria="theme.dark" aria-label="Cambiar a modo oscuro">
          <svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M21 14.5A8.5 8.5 0 1 1 9.5 3a7 7 0 0 0 11.5 11.5Z"></path>
          </svg>
          <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <circle cx="12" cy="12" r="4"></circle>
            <path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"></path>
          </svg>
        </button>
      </div>
    </nav>

    <div class="relative z-10 mx-auto max-w-6xl px-4 pb-8 pt-4 md:pb-10 md:pt-6">
      <div class="grid items-end gap-6 md:grid-cols-[1.2fr_0.8fr]">
        <div>
          <p class="anim-fade-up inline-flex w-fit items-center gap-2 rounded-full bg-dorado/15 px-3 py-1 text-xs font-semibold uppercase tracking-[0.14em] text-dorado ring-1 ring-dorado/40">
            <span class="h-1.5 w-1.5 rounded-full bg-neon" aria-hidden="true"></span>
            <span data-i18n="hero.badge">Mapa · moneda · reservas · accesibilidad</span>
          </p>
          <h1 class="anim-fade-up anim-delay-1 mt-3 font-sans text-4xl font-extrabold leading-[1.08] text-white md:text-5xl">
            La Paz Tour
          </h1>
          <p class="anim-fade-up anim-delay-2 mt-3 max-w-lg text-base text-white/80 md:text-lg" data-i18n="hero.lead">
            Todo centralizado: cuánto vale tu plata, si puedes entrar en silla de ruedas, la ruta dibujada en el mapa y entradas en un clic.
          </p>
          <div class="anim-fade-up anim-delay-2 mt-5 flex flex-wrap gap-3">
            <a href="#conversor" class="btn-accent" data-i18n="hero.cta.currency">Convertir mi moneda</a>
            <a href="#experiencias" class="border border-white/30 px-5 py-2.5 text-sm font-semibold text-white transition hover:border-dorado hover:text-dorado" data-i18n="hero.cta.exp">
              Ver experiencias
            </a>
          </div>
        </div>
        <div class="anim-fade-up anim-delay-2 hidden rounded-sm border border-white/10 bg-white/5 p-4 backdrop-blur-sm md:block">
          <p class="text-xs font-semibold uppercase tracking-wider text-dorado" data-i18n="hero.glance">En un vistazo</p>
          <ul class="mt-3 space-y-2 text-sm text-white/80">
            <li class="flex justify-between gap-4 border-b border-white/10 pb-2">
              <span data-i18n="hero.accessible">Lugares accesibles</span>
              <strong class="text-neon">{accesibles}</strong>
            </li>
            <li class="flex justify-between gap-4 border-b border-white/10 pb-2">
              <span data-i18n="hero.converter">Conversor multi-moneda</span>
              <strong class="text-dorado" data-i18n="hero.yes">Sí</strong>
            </li>
            <li class="flex justify-between gap-4">
              <span data-i18n="hero.bookings">Reservas demo</span>
              <strong class="text-[#D6EEF8]" data-i18n="hero.ready">Listas</strong>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </header>

  <main class="mx-auto max-w-6xl px-4 py-10 md:py-14">
    <Conversor />

    <Diferencial />

    <!-- Accesibilidad: filtro protagonista -->
    <section
      id="accesibilidad"
      class="filter-panel filter-panel-box mb-10 p-5 md:p-7"
      aria-labelledby="filtro-titulo"
    >
      <div class="flex flex-col gap-6 lg:flex-row lg:items-center lg:justify-between">
        <div class="max-w-xl">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-dorado dark:text-neon" data-i18n="filter.eyebrow">
            Pruébalo ahora
          </p>
          <h2 id="filtro-titulo" class="mt-2 font-sans text-2xl font-extrabold heading md:text-3xl" data-i18n="filter.title">
            Un clic. Solo lugares sin barreras.
          </h2>
          <p class="text-soft mt-2" data-i18n="filter.body">
            Activa el filtro y el mapa deja solo sitios con rampas, baños adaptados o acceso apto para silla de ruedas.
          </p>
        </div>

        <label
          for="filtroAccesible"
          class="flex min-w-[280px] cursor-pointer items-center gap-4 rounded-2xl bg-dorado/15 px-5 py-4 ring-1 ring-dorado/35 transition hover:ring-dorado/55 dark:bg-neon/15 dark:ring-neon/40 dark:hover:ring-neon/60"
        >
          <span class="flex h-12 w-12 items-center justify-center rounded-full bg-marino text-dorado dark:bg-neon dark:text-marino" aria-hidden="true">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
              <circle cx="12" cy="5" r="2.2"></circle>
              <path d="M12 7.5v4.5l3.5 2.5"></path>
              <path d="M7 20.5a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5Z"></path>
              <path d="M17 20.5a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5Z"></path>
              <path d="M9.5 15.5h5"></path>
              <path d="M12 12v3.5"></path>
            </svg>
          </span>
          <span class="flex-1">
            <span class="block text-sm font-bold heading" data-i18n="filter.toggle">Solo accesibles</span>
            <span class="text-soft-xs block text-xs" data-i18n="filter.toggle.sub">Silla de ruedas · rampas · baños</span>
          </span>
          <input type="checkbox" id="filtroAccesible" class="sr-only" />
          <span class="toggle-track" aria-hidden="true"></span>
        </label>
      </div>

      <div class="mt-5 flex flex-wrap gap-2 text-xs">
        <span class="rounded-full bg-celeste px-3 py-1 font-medium text-marino dark:bg-marino dark:text-[#D6EEF8]" data-i18n="filter.chip.tourists">Turistas</span>
        <span class="rounded-full bg-verde-ok/15 px-3 py-1 font-medium text-verde-ok dark:bg-neon/15 dark:text-neon" data-i18n="filter.chip.wheel">Silla de ruedas</span>
        <span class="rounded-full bg-rosa/30 px-3 py-1 font-medium text-marino dark:bg-rosa/25 dark:text-rosa" data-i18n="filter.chip.family">Familias</span>
        <span class="rounded-full bg-amarillo/30 px-3 py-1 font-medium text-marino dark:bg-amarillo/20 dark:text-amarillo" data-i18n="filter.chip.days">1.5 días</span>
      </div>
    </section>

    <!-- Mapa -->
    <section id="mapa-section" class="mb-20 scroll-mt-6">
      <div class="mb-6 flex flex-col gap-2 md:flex-row md:items-end md:justify-between">
        <div>
          <h2 class="font-sans text-3xl font-extrabold heading md:text-4xl" data-i18n="map.title">Mapa interactivo</h2>
          <p class="text-soft mt-2 max-w-xl" data-i18n="map.sub">
            Toca un lugar o elige una ruta. Verás la línea guía, precios y cómo llegar.
          </p>
        </div>
        <button
          type="button"
          id="btnResetMapa"
          class="self-start text-sm font-semibold text-dorado underline-offset-2 hover:underline dark:text-neon"
          data-i18n="map.reset"
        >
          Ver toda La Paz
        </button>
      </div>
      <Mapa />
    </section>

    <!-- Rutas -->
    <section id="rutas" class="mb-20 scroll-mt-6">
      <h2 class="font-sans text-3xl font-extrabold heading" data-i18n="routes.title">Rutas turísticas</h2>
      <p class="text-soft mt-2 mb-8 max-w-xl" data-i18n="routes.sub">
        Elige una ruta y verás la línea guía en el mapa — como el camino en un juego.
      </p>
      <Rutas />
    </section>

    <Experiencias />

    <!-- Comercios -->
    <section id="comercios" class="mb-20 scroll-mt-6">
      <h2 class="font-sans text-3xl font-extrabold heading" data-i18n="shops.title">Comercios locales</h2>
      <p class="text-soft mt-2 mb-8 max-w-xl" data-i18n="shops.sub">
        Apoya a artesanos, cafés y negocios del barrio.
      </p>
      <Comercios />
    </section>

    <!-- Aliados -->
    <section id="aliados" class="mb-16 scroll-mt-6">
      <h2 class="font-sans text-3xl font-extrabold heading" data-i18n="allies.title">Nuestros aliados</h2>
      <p class="text-soft mt-2 mb-8 max-w-xl" data-i18n="allies.sub">
        Incluye a FEDEBOL y otros socios que validan la accesibilidad real.
      </p>
      <Aliados />
    </section>

    <footer class="border-t border-marino/15 py-10 text-center text-sm text-soft dark:border-white/10">
      <p data-i18n="footer">© 2026 La Paz Tour — La Paz sin barreras, con economía local</p>
    </footer>
  </main>
</Layout>

<script>
  import { lugares, rutas } from '../data/data.js';

  /** @type {any} */
  let mapa = null;
  /** @type {any} */
  let capaTiles = null;
  /** @type {any} */
  let marcadorUsuario = null;
  /** @type {any} */
  let polyRuta = null;
  /** @type {any[]} */
  let marcadoresRuta = [];
  /** @type {string | null} */
  let rutaActivaId = null;
  /** @type {Map<number, any>} */
  const marcadoresById = new Map();
  /** @type {number | null} */
  let seleccionadoId = null;

  const CENTRO_LA_PAZ = { lat: -16.5, lng: -68.15, zoom: 13 };

  function lugaresVisiblesBase() {
    return lugares.filter((l) => !l.ocultoLista);
  }

  function urlTiles() {
    return 'https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}.png';
  }

  function aplicarCapaTiles() {
    if (!mapa || !window.L) return;
    if (capaTiles) mapa.removeLayer(capaTiles);
    capaTiles = window.L.tileLayer(urlTiles(), {
      attribution:
        '&copy; <a href="https://www.openstreetmap.org/copyright">OSM</a> &copy; <a href="https://carto.com/">CARTO</a>',
      maxZoom: 19,
      subdomains: 'abcd',
    }).addTo(mapa);
    const el = document.getElementById('mapa');
    if (el) el.style.background = '#d4e4f0';
  }

  function iconoUsuario() {
    return window.L.divIcon({
      className: '',
      html: `<div style="width:18px;height:18px;border-radius:50%;background:#2563eb;border:3px solid #fff;box-shadow:0 0 0 6px rgba(37,99,235,.25),0 2px 8px rgba(0,0,0,.3);"></div>`,
      iconSize: [18, 18],
      iconAnchor: [9, 9],
    });
  }

  function iconoPaso(n, color) {
    return window.L.divIcon({
      className: '',
      html: `<div class="route-step-pin" style="background:${color}">${n}</div>`,
      iconSize: [28, 28],
      iconAnchor: [14, 14],
    });
  }

  function centrarLaPaz() {
    if (!mapa) return;
    mapa.flyTo([CENTRO_LA_PAZ.lat, CENTRO_LA_PAZ.lng], CENTRO_LA_PAZ.zoom, { duration: 0.8 });
  }

  function mostrarUbicacionUsuario(lat, lng) {
    if (!mapa || !window.L) return;
    if (marcadorUsuario) mapa.removeLayer(marcadorUsuario);
    marcadorUsuario = window.L.marker([lat, lng], {
      title: 'Tu ubicación',
      icon: iconoUsuario(),
      zIndexOffset: 1000,
    }).addTo(mapa);
    marcadorUsuario.bindPopup(`<strong>${(window.lptT || ((k) => k))('map.here')}</strong>`);
    mapa.flyTo([lat, lng], 15, { duration: 0.9 });
    setTimeout(() => marcadorUsuario.openPopup(), 500);
  }

  function ubicarme() {
    const btn = /** @type {HTMLButtonElement | null} */ (document.getElementById('btnUbicarme'));
    if (!mapa) return;
    const listo = () => {
      if (btn) {
        btn.disabled = false;
        btn.setAttribute('aria-busy', 'false');
      }
    };
    if (!navigator.geolocation) {
      centrarLaPaz();
      listo();
      return;
    }
    if (btn) {
      btn.disabled = true;
      btn.setAttribute('aria-busy', 'true');
    }
    navigator.geolocation.getCurrentPosition(
      (pos) => {
        mostrarUbicacionUsuario(pos.coords.latitude, pos.coords.longitude);
        listo();
      },
      () => {
        centrarLaPaz();
        listo();
      },
      { enableHighAccuracy: true, timeout: 8000, maximumAge: 60000 }
    );
  }

  function iconoLugar(lugar, activo = false) {
    const ok = lugar.accesible;
    return window.L.divIcon({
      className: '',
      html: `<div class="map-pin ${ok ? 'is-ok' : 'is-no'} ${activo ? 'is-active' : ''}"><span>${ok ? '♿' : '·'}</span></div>`,
      iconSize: [34, 34],
      iconAnchor: [17, 30],
      popupAnchor: [0, -28],
    });
  }

  function precioTexto(bob) {
    const fmt = window.lptFormatPrecio;
    const code = window.lptGetMoneda?.() || 'USD';
    const tr = window.lptT || ((k) => k);
    if (!bob || bob <= 0) return tr('map.free');
    return fmt ? fmt(bob, code) : `Bs ${bob}`;
  }

  function popupHtml(lugar) {
    const tr = window.lptT || ((k) => k);
    const badge = lugar.accesible
      ? `<span class="badge ok">♿ ${tr('map.accessible')}</span>`
      : `<span class="badge no">${tr('map.limited')}</span>`;
    const tags = (lugar.features || []).map((f) => `<span>${f}</span>`).join('');
    const mapsUrl = `https://www.google.com/maps/dir/?api=1&destination=${lugar.lat},${lugar.lng}`;
    const tel = lugar.telefono
      ? `<p style="margin:6px 0 0;font-size:.8rem"><a href="tel:+591${lugar.telefono}">📞 +591 ${lugar.telefono}</a></p>`
      : '';
    const wa = lugar.whatsapp
      ? `<p style="margin:4px 0 0;font-size:.8rem"><a href="https://wa.me/${lugar.whatsapp}" target="_blank" rel="noopener">WhatsApp</a></p>`
      : '';
    const precio = `<p style="margin:8px 0 0;font-size:.85rem;font-weight:700">${precioTexto(lugar.entradaBob)}</p>`;
    const horario = lugar.horario ? `<p style="margin:4px 0 0;font-size:.75rem;color:#666">${lugar.horario}</p>` : '';

    return `
      <div class="marker-popup">
        <img src="${lugar.foto}" alt="${lugar.nombre}" loading="lazy" />
        <div class="body">
          <h3>${lugar.nombre}</h3>
          <p class="desc">${lugar.descripcion}</p>
          ${badge}
          <div class="tags">${tags}</div>
          ${precio}
          ${horario}
          ${tel}
          ${wa}
          <a href="${mapsUrl}" target="_blank" rel="noopener noreferrer">→</a>
        </div>
      </div>
    `;
  }

  function actualizarContador(n, soloAccesibles) {
    const el = document.getElementById('contadorMarcadores');
    if (!el) return;
    el.textContent = soloAccesibles
      ? `${n} lugar${n === 1 ? '' : 'es'} accesible${n === 1 ? '' : 's'}`
      : `${n} lugares`;
  }

  function renderLista(lista) {
    const ul = document.getElementById('listaLugares');
    if (!ul) return;
    ul.innerHTML = lista
      .map(
        (l) => `
      <li>
        <button type="button" class="lugar-item flex w-full items-start gap-3 rounded-xl border border-transparent px-3 py-3 text-left font-sans ${seleccionadoId === l.id ? 'is-selected' : ''}" data-id="${l.id}" role="option" aria-selected="${seleccionadoId === l.id}">
          <span class="mt-0.5 flex h-8 w-8 shrink-0 items-center justify-center rounded-full text-sm ${l.accesible ? 'lugar-badge-ok' : 'lugar-badge-no'}" aria-hidden="true">${l.accesible ? '♿' : '!'}</span>
          <span class="min-w-0">
            <span class="block truncate font-semibold heading">${l.nombre}</span>
            <span class="text-soft-xs mt-0.5 block text-xs">${l.ruta} · ${precioTexto(l.entradaBob)}</span>
          </span>
        </button>
      </li>`
      )
      .join('');

    ul.querySelectorAll('[data-id]').forEach((btn) => {
      btn.addEventListener('click', () => enfocarLugar(Number(btn.getAttribute('data-id'))));
    });
  }

  function limpiarMarcadores() {
    marcadoresById.forEach((m) => mapa.removeLayer(m));
    marcadoresById.clear();
  }

  function limpiarRutaCapa() {
    if (polyRuta) {
      mapa.removeLayer(polyRuta);
      polyRuta = null;
    }
    marcadoresRuta.forEach((m) => mapa.removeLayer(m));
    marcadoresRuta = [];
  }

  function agregarMarcadores(lista) {
    lista.forEach((lugar) => {
      const marker = window.L.marker([lugar.lat, lugar.lng], {
        title: lugar.nombre,
        icon: iconoLugar(lugar, seleccionadoId === lugar.id),
        riseOnHover: true,
      }).addTo(mapa);
      marker.bindPopup(popupHtml(lugar), { maxWidth: 280 });
      marker.on('click', () => {
        seleccionadoId = lugar.id;
        resaltarMarcadores();
        renderLista(listaVisible());
        document.querySelector(`[data-id="${lugar.id}"]`)?.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
      });
      marcadoresById.set(lugar.id, marker);
    });
  }

  function resaltarMarcadores() {
    marcadoresById.forEach((marker, id) => {
      const lugar = lugares.find((l) => l.id === id);
      if (!lugar) return;
      marker.setIcon(iconoLugar(lugar, id === seleccionadoId));
      marker.setPopupContent(popupHtml(lugar));
    });
  }

  function listaVisible() {
    const filtro = /** @type {HTMLInputElement | null} */ (document.getElementById('filtroAccesible'));
    const solo = filtro?.checked ?? false;
    let lista = lugaresVisiblesBase();
    if (rutaActivaId) {
      const ruta = rutas.find((r) => r.id === rutaActivaId);
      if (ruta) {
        const set = new Set(ruta.lugares);
        lista = lugares.filter((l) => set.has(l.id));
      }
    }
    if (solo) lista = lista.filter((l) => l.accesible);
    return lista;
  }

  function mostrarRuta(rutaId) {
    if (!mapa || !window.L) return;
    const ruta = rutas.find((r) => r.id === rutaId);
    const sel = /** @type {HTMLSelectElement | null} */ (document.getElementById('selectRuta'));
    const hint = document.getElementById('rutaActivaHint');

    if (!ruta) {
      rutaActivaId = null;
      if (sel) sel.value = '';
      if (hint) hint.textContent = '';
      limpiarRutaCapa();
      aplicarFiltro();
      return;
    }

    rutaActivaId = ruta.id;
    if (sel) sel.value = ruta.id;
    limpiarRutaCapa();

    const pts = ruta.lugares
      .map((id) => lugares.find((l) => l.id === id))
      .filter(Boolean);

    const latlngs = pts.map((p) => [p.lat, p.lng]);
    polyRuta = window.L.polyline(latlngs, {
      color: ruta.color || '#C9A227',
      weight: 5,
      opacity: 0.9,
      dashArray: '10 8',
      lineJoin: 'round',
    }).addTo(mapa);

    // Línea sólida debajo (efecto guía)
    const glow = window.L.polyline(latlngs, {
      color: ruta.color || '#C9A227',
      weight: 10,
      opacity: 0.2,
    }).addTo(mapa);
    marcadoresRuta.push(glow);

    pts.forEach((p, i) => {
      const m = window.L.marker([p.lat, p.lng], {
        icon: iconoPaso(i + 1, ruta.color || '#C9A227'),
        zIndexOffset: 800,
      }).addTo(mapa);
      m.bindPopup(popupHtml(p), { maxWidth: 280 });
      marcadoresRuta.push(m);
    });

    if (hint) {
      hint.textContent = `Guía activa: ${ruta.nombre} · ${pts.length} paradas · ${precioTexto(ruta.precioBob)}`;
    }

    aplicarFiltro(false);
    if (latlngs.length) {
      mapa.fitBounds(window.L.latLngBounds(latlngs).pad(0.25));
    }
  }

  function aplicarFiltro(fit = true) {
    const filtro = /** @type {HTMLInputElement | null} */ (document.getElementById('filtroAccesible'));
    const solo = filtro?.checked ?? false;
    document.querySelector('.filter-panel')?.classList.toggle('is-active', solo);

    const lista = listaVisible();
    if (seleccionadoId && !lista.some((l) => l.id === seleccionadoId)) seleccionadoId = null;

    limpiarMarcadores();
    // Si hay ruta activa, los pins numerados ya están; igual mostramos pins estándar de la lista
    if (!rutaActivaId) agregarMarcadores(lista);
    else agregarMarcadores(lista);

    renderLista(lista);
    actualizarContador(lista.length, solo);

    if (fit && !rutaActivaId && lista.length > 0) {
      mapa.fitBounds(window.L.latLngBounds(lista.map((l) => [l.lat, l.lng])).pad(0.18));
    }
  }

  function enfocarLugar(id) {
    const lugar = lugares.find((l) => l.id === id);
    const marker = marcadoresById.get(id);
    if (!lugar) return;
    seleccionadoId = id;
    resaltarMarcadores();
    renderLista(listaVisible());
    mapa.flyTo([lugar.lat, lugar.lng], 16, { duration: 0.85 });
    if (marker) setTimeout(() => marker.openPopup(), 500);
  }

  function iniciarMapa() {
    const el = document.getElementById('mapa');
    if (!el || !window.L) return;

    mapa = window.L.map(el, { zoomControl: false, scrollWheelZoom: true }).setView([-16.5, -68.15], 13);
    window.L.control.zoom({ position: 'topright' }).addTo(mapa);
    aplicarCapaTiles();
    aplicarFiltro();

    document.getElementById('filtroAccesible')?.addEventListener('change', () => aplicarFiltro());
    document.getElementById('btnResetMapa')?.addEventListener('click', () => {
      seleccionadoId = null;
      mostrarRuta(null);
    });
    document.getElementById('btnUbicarme')?.addEventListener('click', ubicarme);
    document.getElementById('selectRuta')?.addEventListener('change', (e) => {
      const v = /** @type {HTMLSelectElement} */ (e.target).value;
      mostrarRuta(v || null);
    });
    document.getElementById('btnLimpiarRuta')?.addEventListener('click', () => mostrarRuta(null));

    window.addEventListener('lpt-show-route', (e) => {
      const id = e.detail?.id;
      if (id) mostrarRuta(id);
    });

    window.addEventListener('lpt-currency-change', () => {
      resaltarMarcadores();
      renderLista(listaVisible());
      if (rutaActivaId) {
        const ruta = rutas.find((r) => r.id === rutaActivaId);
        const hint = document.getElementById('rutaActivaHint');
        if (ruta && hint) {
          hint.textContent = `${ruta.nombre} · ${ruta.lugares.length} · ${precioTexto(ruta.precioBob)}`;
        }
      }
    });

    window.addEventListener('lpt-lang-change', () => {
      resaltarMarcadores();
      renderLista(listaVisible());
      const opt = document.querySelector('#selectRuta option[value=""]');
      if (opt) opt.textContent = (window.lptT || ((k) => k))('map.all');
    });

    window.addEventListener('lpt-theme-change', () => {
      aplicarCapaTiles();
      setTimeout(() => mapa.invalidateSize(), 50);
    });

    setTimeout(() => mapa.invalidateSize(), 120);
    window.addEventListener('resize', () => mapa.invalidateSize());
  }

  function esperarLeaflet() {
    if (window.L) iniciarMapa();
    else setTimeout(esperarLeaflet, 50);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', esperarLeaflet);
  } else {
    esperarLeaflet();
  }
</script>
